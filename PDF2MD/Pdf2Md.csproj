<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>10</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>pdf2md</AssemblyName>
    <RootNamespace>Pdf2Md</RootNamespace>
    <Version>1.0.0</Version>
    <Description>Converts PDF files to HTML or Markdown, with image extraction.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FileSignatures" Version="7.2.0" />
    <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="14.13.0" />
    <PackageReference Include="PdfPig" Version="0.1.14" />
    <PackageReference Include="Spectre.Console.Cli" Version="0.55.0" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>CliVersion</_Parameter1>
      <_Parameter2>$(Version)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
